alias reload='exec zsh -l'
alias tmux-reload="tmux source-file ~/.config/tmux/tmux.conf"

alias cls='clear'

# Easier navigation: .., ..., ...., ....., ~ and -
alias ..="cd .."
alias ...="cd ../.."
alias ....="cd ../../.."
alias .....="cd ../../../.."
alias cl="clear"
alias cd="z"
alias oo='cd "$HOME/Library/Mobile Documents/iCloud~md~obsidian/Documents"'

# ── eza-powered directory listings ───────────────────────────────────────
# plain “ls” → detailed list (+icons, coloured), no user column
alias ls='eza --color=always --icons --no-user'

# “l”  → short , human-readable sizes
alias l='eza --no-permissions --color=always --icons --no-user --bytes'

# “la” → long, all files (incl. dotfiles)
alias la='eza --long --all --color=always --icons --no-user --bytes'
alias lsa=la

# “lsd” → only directories
alias lsd='eza -lh --only-dirs --color=always --icons --no-user'

# ── copy current path to clipboard (macOS pbcopy) ────────────────────────
alias cpwd="pwd | tr -d '\n' | pbcopy"

# Shortcuts
alias dl="cd ~/Downloads"
alias h="history"

# Always enable colored `grep` output
alias grep='grep --color=auto '

# Get week number
alias week='date +%V'

# Copy public key to clipboard
alias pubkey="more ~/.ssh/id_ed25519.pub | pbcopy | echo '=> Public key copied to pasteboard.'"

# Convenience
alias cat=bat
alias how=tldr
alias pcopy=pbcopy
alias ppaste=pbpaste
alias v=nvim
alias vim=nvim
alias cursor="cursor-agent"

# Search files
alias f="fzf | xargs -I {} nvim \"{}\""
alias fd='cd "$(find . -type d -not -path "*/.git/*" | fzf --no-preview)"'

# Fuzzy-search grep results and open the selected match
alias ffg="grep --line-number --color=always -r --exclude-dir=.git '' . \
  | fzf --ansi --delimiter ':' --preview 'bat --style=numbers --color=always --highlight-line {2} {1}' \
  | awk -F: '{print \$1, \$2}' \
  | xargs -r -n2 sh -c 'nvim +\$1 \"\$0\"'"

# -- docker
alias docker-clean='docker container prune -f && docker image prune -af && docker volume prune -f && docker builder prune -af'

# -- mitmproxy local proxy setup
alias proxy-local='
    IP=$(ipconfig getifaddr en0 || ipconfig getifaddr en1)
    echo "Your IP: $IP | Proxy: $IP:8888"
    echo "$IP" | pbcopy
    echo " IP copied to clipboard!"
    echo "Press Enter to start mitmproxy..."
    read
    mitmproxy --mode regular@8888 \
        --ignore "~u \.png$ | ~u logo" \
        --ssl-insecure
        --no-http2
'

# -- git

alias g="git"
alias lg=lazygit

# Status / branches
alias gs='git status'
alias gb='git branch'
alias gba='git branch --all'
alias gbd='git branch --delete'

# Add / commit
alias ga='git add'
alias gaa='git add --all'
alias gap='git add --patch'
alias gc='git commit'
alias gcm='git commit -m'
alias gca='git commit -a'
alias gcam='git commit -a -m'

# Diff / log
alias gd='git diff'
alias gds='git diff --staged'
# Pretty single-line log graph across all refs.
alias glog="git log --color --graph --pretty=format:'%C(bold blue)%h%C(reset) -%C(auto)%d%C(reset) %s %C(bold green)(%cr)%C(reset) %C(dim white)<%an>%C(reset)' --abbrev-commit"
alias glog1="git log --graph --abbrev-commit --decorate --format=format:'%C(bold blue)%h%C(reset) - %C(bold green)(%ar)%C(reset) %C(white)%s%C(reset) %C(dim white)- %an%C(reset)%C(auto)%d%C(reset)' --all"
alias lg2="git log --graph --abbrev-commit --decorate --format=format:'%C(bold blue)%h%C(reset) - %C(bold cyan)%aD%C(reset) %C(bold green)(%ar)%C(reset)%C(auto)%d%C(reset)%n''          %C(white)%s%C(reset) %C(dim white)- %an%C(reset)'"

# Push / pull
alias gp='git push'
alias gpl='git pull'
# Safer force push (refuses if remote has new commits you don't have).
alias gpf='git push --force-with-lease'

# Stash / restore
alias gst='git stash'
alias gsp='git stash pop'
# Unstage a file (keep working-tree changes).
alias grs='git restore --staged'
# Discard working-tree changes for a file.
alias gr='git restore'

# Navigation
# Jump to repo root.
alias grt='cd "$(git rev-parse --show-toplevel || echo .)"'
# Fuzzy-find a local or remote branch and check it out.
alias gco='git checkout $(git branch --all --format="%(refname:short)" | sed "s#^remotes/##" | sort -u | fzf --height 40% --layout=reverse --prompt="branch> " --preview="git log --oneline --decorate --graph --color=always {} | head -80")'

# Maintenance
# Fetch + prune, pull, then delete local branches whose upstream is gone.
alias git-sync="git fetch --prune && git pull && git branch -vv | awk '/: gone]/{print $1}' | xargs -r git branch -d"
# Delete local branches already merged into HEAD (skips master/main/dev/current).
alias git-purge='git branch --merged | egrep -v "(^\*|master|main|dev)" | xargs git branch -d'
# Hard-reset all submodules — wipes uncommitted submodule changes.
alias submodule-reset='git submodule deinit -f . && git submodule update --init --recursive'


# Quick port scan: -Pn skip ping, -F top 100 ports, -sV detect service/version.
alias scan='nmap -Pn -F -sV'
