#!/usr/bin/env bash

# Create or reuse worktrees for one branch across multiple repositories,
# then send the same OpenCode review command to every tmux pane.
#
# Usage:
#   worktrees-review <branch> [--skip-unchanged] [--base=<branch>] [--attach]
#   worktrees-review <branch> <destination> <repo-path...> [--skip-unchanged] [--base=<branch>] [--attach]
#
# Notes:
#   - Uses tmux session: reviews
#   - Sends a fixed OpenCode prompt to each pane
#   - --skip-unchanged and --base are forwarded to `worktrees`
#   - --attach attaches after review commands are sent
#   - branch-only mode uses current repo with destination at ./reviews
#
# Examples:
#   worktrees-review linux
#   worktrees-review linux --skip-unchanged
#   worktrees-review linux --base=develop
#   worktrees-review linux --attach
#   worktrees-review linux ~/reviews ~/repo/a ~/repo/b --skip-unchanged

set -euo pipefail

usage() {
	printf 'Usage:\n' >&2
	printf '  %s <branch> [--skip-unchanged] [--base=<branch>] [--attach]\n' "$(basename "$0")" >&2
	printf '  %s <branch> <destination> <repo-path...> [--skip-unchanged] [--base=<branch>] [--attach]\n' "$(basename "$0")" >&2
	printf '\nExamples:\n' >&2
	printf '  %s linux\n' "$(basename "$0")" >&2
	printf '  %s linux --skip-unchanged --base=develop\n' "$(basename "$0")" >&2
	printf '  %s linux --attach\n' "$(basename "$0")" >&2
	printf '  %s linux ~/reviews ~/repo/a ~/repo/b --skip-unchanged\n' "$(basename "$0")" >&2
	printf '\nOptions:\n' >&2
	printf '  -h, --help                  show help\n' >&2
	printf '      --skip-unchanged        forward to worktrees\n' >&2
	printf '      --base=<branch>         forward to worktrees\n' >&2
	printf '      --attach                attach after sending review commands\n' >&2
}

REPOS=()
SKIP_SAME=0
BASE_BRANCH=""
ATTACH=0
POSITIONAL=()

if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
	usage
	exit 0
fi

if [ "$#" -lt 1 ] || [[ "$1" == --* ]]; then
	usage
	exit 1
fi

BRANCH="$1"
DESTINATION=""
shift

for ARG in "$@"; do
	if [ "$ARG" = "--skip-unchanged" ]; then
		SKIP_SAME=1
	elif [ "$ARG" = "--attach" ]; then
		ATTACH=1
	elif [[ "$ARG" == --base=* ]]; then
		BASE_BRANCH="${ARG#--base=}"
		if [ -z "$BASE_BRANCH" ]; then
			printf 'Base branch cannot be empty.\n' >&2
			usage
			exit 1
		fi
	elif [[ "$ARG" == --* ]]; then
		printf 'Unknown flag: %s\n' "$ARG" >&2
		usage
		exit 1
	else
		POSITIONAL+=("$ARG")
	fi
done

if [ "${#POSITIONAL[@]}" -eq 0 ]; then
	if ! REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"; then
		printf 'Branch-only mode requires running inside a git repository.\n' >&2
		exit 1
	fi
	DESTINATION="$REPO_ROOT/reviews"
	REPOS=("$REPO_ROOT")
	printf 'Using current repo: %s\n' "$REPO_ROOT"
else
	if [ "${#POSITIONAL[@]}" -lt 2 ]; then
		printf 'When passing positional args after <branch>, provide both <destination> and at least one <repo-path>.\n' >&2
		usage
		exit 1
	fi
	DESTINATION="${POSITIONAL[0]}"
	REPOS=("${POSITIONAL[@]:1}")
fi

SESSION="reviews"
PROMPT='Code review this branch. If there are no changes on this branch, stop and report no changes.'

WORKTREES_ARGS=("$BRANCH" "$DESTINATION" "${REPOS[@]}" "--session=$SESSION")
if [ "$SKIP_SAME" -eq 1 ]; then
	WORKTREES_ARGS+=("--skip-unchanged")
fi
if [ -n "$BASE_BRANCH" ]; then
	WORKTREES_ARGS+=("--base=$BASE_BRANCH")
fi

if ! worktrees "${WORKTREES_ARGS[@]}"; then
	exit 1
fi

WINDOW_TARGET="$(tmux list-windows -t "$SESSION" -F '#{window_active} #{session_name}:#{window_name}' | grep '^1 ' | head -n 1 | cut -d' ' -f2-)"

if [ -z "$WINDOW_TARGET" ]; then
	printf 'Could not determine active tmux window in session %s.\n' "$SESSION" >&2
	exit 1
fi

ESCAPED_PROMPT="${PROMPT//\'/\'\\\'\'}"
COMMAND="opencode --prompt '$ESCAPED_PROMPT'"
# COMMAND="opencode run '$ESCAPED_PROMPT'" --- cant get this to work because of the permissions...

printf 'Running in each pane: %s\n' "$COMMAND"

while IFS= read -r pane; do
	tmux send-keys -t "$pane" "$COMMAND" Enter
done < <(tmux list-panes -t "$WINDOW_TARGET" -F '#{session_name}:#{window_name}.#{pane_index}')

printf 'Sent review command to panes in %s\n' "$WINDOW_TARGET"

if [ "$ATTACH" -eq 1 ]; then
	if [ -z "${TMUX:-}" ]; then
		tmux attach -t "$WINDOW_TARGET"
	else
		tmux switch-client -t "$SESSION"
		tmux select-window -t "$WINDOW_TARGET"
	fi
fi
