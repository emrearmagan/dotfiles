{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    // MCPs
    "context7_*": "allow",
    "github_*": "ask",

    "webfetch": "allow",
    "websearch": "allow",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.dev.vars": "deny",
      "*.env.example": "allow",
    },
    "external_directory": {
      "*": "ask",
      "~/development/**": "allow",
      "/tmp/**": "allow",
      "/private/tmp/**": "allow",
    },
    "edit": "ask",
    "bash": {
      "*": "ask",
      "ls *": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "find *": "allow",
      "rg *": "allow",
      "grep *": "allow",
      "rtk *": "allow",

      // Git
      "git status *": "allow",
      "git branch *": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "git diff *": "allow",
      "git remote *": "allow",
      "git rev-parse *": "allow",
      "git merge-base *": "allow",
      "git reflog *": "allow",
      "git tag *": "allow",
      "git show-ref *": "allow",

      // System info
      "type *": "allow",
      "file *": "allow",
      "stat *": "allow",
      "du *": "allow",
      "df *": "allow",
      "pwd": "allow",
      "printf *": "allow",

      // Docker
      "docker ps *": "allow",
    },
  },
  "plugin": [
    "superpowers@git+https://github.com/obra/superpowers.git",

    // https://github.com/Opencode-DCP/opencode-dynamic-context-pruning
    "@tarquinen/opencode-dcp@latest",

    // https://github.com/mohak34/opencode-notifier
    "@mohak34/opencode-notifier@latest",
  ],
  "model": "openai/gpt-5.3-codex",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "https://ollama.local.emrearmagan.dev/v1",
      },
      "models": {
        "qwen3:8b": {
          "name": "Qwen 3 8B",
          "tools": true,
        },
        "qwen3-coder:30b": {
          "name": "Qwen 3 30B",
          "tools": true,
        },
        "qwen2.5-coder:7b": {
          "name": "qwen2.5-coder 7B",
          "tools": true,
        },
      },
    },
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}",
      },
    },
    "github": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-github"],
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{env:GITHUB_PUBLIC_ACCESS_TOKEN}",
      },
    },
  },
}
