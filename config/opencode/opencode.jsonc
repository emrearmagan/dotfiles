{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "webfetch": "allow",
    "websearch": "allow",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.dev.vars": "deny",
      "*.env.example": "allow"
    },
    "external_directory": {
      "*": "ask",
      "~/development/**": "allow",
      "/tmp/**": "allow",
      "/private/tmp/**": "allow"
    },
    "edit": "ask",
    "bash": {
      "*": "ask",
      "ls *": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "find *": "allow",
      "rg *": "allow",
      "grep *": "allow",

      // Git
      "git status *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git branch *": "allow",
      "git show *": "allow",
      "git stash list *": "allow",
      "git remote *": "allow",
      "git fetch *": "allow",
      "git pull *": "allow",
      "git worktree *": "allow",

      // System info
      "type *": "allow",
      "file *": "allow",
      "stat *": "allow",
      "du *": "allow",
      "df *": "allow",
      "pwd": "allow",
      "echo *": "allow",
      "printf *": "allow",
      "mkdir *": "allow",
      "cp *": "allow",
      "mv *": "allow",
      // Docker
      "docker ps *": "allow",
    }
  },
  "model": "openai/gpt-4o",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "https://ollama.local.emrearmagan.dev/v1"
      },
      "models": {
        "qwen3:8b": {
          "name": "Qwen 3 8B",
          "tools": true
        },
        "phi4-mini:3.8b": {
          "name": "Phi 4 Mini 3.8B",
          "tools": true
        },
        "llama3.2:3b": {
          "name": "Llama 3.2 3B",
          "tools": true
        },
        "qwen2.5-coder:7b": {
          "name": "qwen2.5-coder 7B",
          "tools": true
        }
      }
    }
  }
}
