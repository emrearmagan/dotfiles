{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    // MCPs
    "context7_*": "allow",
    "github_*": "ask",

    "webfetch": "allow",
    "websearch": "allow",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.dev.vars": "deny",
      "*.env.example": "allow"
    },
    "external_directory": {
      "*": "ask",
      "~/development/**": "allow",
      "/tmp/**": "allow",
      "/private/tmp/**": "allow"
    },
    "edit": "ask",
    "bash": {
      "*": "ask",
      "ls *": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "find *": "allow",
      "rg *": "allow",
      "grep *": "allow",

      // System info
      "type *": "allow",
      "file *": "allow",
      "stat *": "allow",
      "du *": "allow",
      "df *": "allow",
      "pwd": "allow",
      "printf *": "allow",

      // Docker
      "docker ps *": "allow",
    }
  },
  "plugin": [
    "superpowers@git+https://github.com/obra/superpowers.git"
  ],
  "model": "openai/gpt-5.3-codex",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "https://ollama.local.emrearmagan.dev/v1"
      },
      "models": {
        "qwen3:8b": {
          "name": "Qwen 3 8B",
          "tools": true
        },
        "phi4-mini:3.8b": {
          "name": "Phi 4 Mini 3.8B",
          "tools": true
        },
        "llama3.2:3b": {
          "name": "Llama 3.2 3B",
          "tools": true
        },
        "qwen2.5-coder:7b": {
          "name": "qwen2.5-coder 7B",
          "tools": true
        }
      }
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      }
    },
    "github": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-github"],
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{env:GITHUB_PUBLIC_ACCESS_TOKEN}"
      }
    }
  }
}
