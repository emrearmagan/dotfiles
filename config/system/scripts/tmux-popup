#!/usr/bin/env bash
set -euo pipefail

socket="popup"
session="popup"
detach=0

tmux_popup() {
	env -u TMUX tmux -L "$socket" "$@"
}

while [ "$#" -gt 0 ]; do
	case "$1" in
	-d)
		detach=1
		shift
		;;
	-h | --help)
		printf 'Usage: %s [-d]\n' "$(basename "$0")"
		exit 0
		;;
	*)
		printf 'Unknown flag: %s\n' "$1" >&2
		exit 1
		;;
	esac
done

if ! tmux_popup has-session -t "$session" 2>/dev/null; then
	tmux_popup new-session -d -s "$session" -c "$PWD"
fi

# The popup server loads the normal tmux config, so keep normal prefix/key behavior
# and override only the keys that should close this popup client.
tmux_popup bind-key t detach-client
tmux_popup bind-key -n Escape detach-client

if [ "$detach" -eq 1 ]; then
	exit 0
fi

exec env -u TMUX tmux -L "$socket" attach-session -t "$session" >/dev/null
