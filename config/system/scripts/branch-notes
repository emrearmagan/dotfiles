#!/usr/bin/env bash

# Manage local branch review notes.
# Notes are stored as formatted JSON under:
#   <canonical-repo-root>/.notes/<branch>/notes.json

set -euo pipefail

need() {
	command -v "$1" >/dev/null 2>&1 || {
		printf 'Missing dependency: %s\n' "$1" >&2
		exit 1
	}
}

usage() {
	printf 'Usage:\n' >&2
	printf '  %s path [--branch <branch>]\n' "$(basename "$0")" >&2
	printf '  %s branches [--json]\n' "$(basename "$0")" >&2
	printf '  %s add --file <path> --line <line> --body <text> [options]\n' "$(basename "$0")" >&2
	printf '  %s update <id> [options]\n' "$(basename "$0")" >&2
	printf '  %s list [--branch <branch>] [--json]\n' "$(basename "$0")" >&2
	printf '  %s delete <id> [--branch <branch>]\n' "$(basename "$0")" >&2
	printf '  %s clear [--branch <branch>] --yes\n' "$(basename "$0")" >&2
	printf '  %s delete-branch --branch <branch> --yes\n' "$(basename "$0")" >&2
	printf '\nOptions for add/update:\n' >&2
	printf '      --title <text>             note title\n' >&2
	printf '      --severity <level>         critical, important, or minor\n' >&2
	printf '      --source <name>            pi or manual (default: pi)\n' >&2
	printf '      --branch <branch>          branch notes bucket (default: current branch)\n' >&2
	printf '      --base-ref <ref>           base ref override\n' >&2
	printf '      --provider <name>          optional PR provider\n' >&2
	printf '      --pr-id <id>               optional PR id/number\n' >&2
}

need git
need jq
need uuidgen

worktree_root() {
	git rev-parse --show-toplevel 2>/dev/null || {
		printf 'Not inside a git repository.\n' >&2
		exit 1
	}
}

canonical_repo_root() {
	local wt common_dir
	wt="$(worktree_root)"
	common_dir="$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null || true)"

	if [ -z "$common_dir" ]; then
		common_dir="$(git rev-parse --git-common-dir 2>/dev/null || true)"
		case "$common_dir" in
		/*) ;;
		*) common_dir="$wt/$common_dir" ;;
		esac
	fi

	if [ -n "$common_dir" ] && [ "$(basename "$common_dir")" = ".git" ]; then
		dirname "$common_dir"
	else
		printf '%s\n' "$wt"
	fi
}

note_branch() {
	local branch sha
	branch="$(git branch --show-current 2>/dev/null || true)"
	if [ -n "$branch" ]; then
		printf '%s\n' "$branch"
		return
	fi

	sha="$(git rev-parse --short=12 HEAD 2>/dev/null || true)"
	printf 'detached-%s\n' "${sha:-HEAD}"
}

notes_root() {
	printf '%s/.notes\n' "$(canonical_repo_root)"
}

notes_dir_for_branch() {
	printf '%s/%s\n' "$(notes_root)" "$1"
}

notes_file_for_branch() {
	printf '%s/notes.json\n' "$(notes_dir_for_branch "$1")"
}

selected_branch() {
	if [ -n "${1:-}" ]; then
		printf '%s\n' "$1"
	else
		note_branch
	fi
}

notes_file() {
	notes_file_for_branch "$(note_branch)"
}

write_json() {
	local target="$1" tmp
	mkdir -p "$(dirname "$target")"
	tmp="$(mktemp "$(dirname "$target")/.notes.XXXXXX")"
	cat >"$tmp"
	mv "$tmp" "$target"
}

now_utc() {
	date -u '+%Y-%m-%dT%H:%M:%SZ'
}

new_id() {
	printf 'note_%s\n' "$(uuidgen | tr '[:upper:]' '[:lower:]' | tr -d '-' | cut -c 1-12)"
}

head_sha() {
	git rev-parse HEAD 2>/dev/null || true
}

default_base_ref() {
	local origin_head
	origin_head="$(git symbolic-ref -q --short refs/remotes/origin/HEAD 2>/dev/null || true)"
	if [ -n "$origin_head" ]; then
		printf '%s\n' "$origin_head"
		return
	fi

	if git rev-parse --verify --quiet origin/main >/dev/null; then
		printf 'origin/main\n'
	elif git rev-parse --verify --quiet origin/master >/dev/null; then
		printf 'origin/master\n'
	fi
}

base_sha_for() {
	local ref="$1"
	[ -n "$ref" ] || return 0
	git merge-base HEAD "$ref" 2>/dev/null || git rev-parse "$ref" 2>/dev/null || true
}

remote_url() {
	git remote get-url origin 2>/dev/null || true
}

relative_path() {
	local wt="$1" input="$2"
	case "$input" in
	"$wt"/*) printf '%s\n' "${input#"$wt"/}" ;;
	./*) printf '%s\n' "${input#./}" ;;
	*) printf '%s\n' "$input" ;;
	esac
}

empty_document() {
	local branch="$1" now="$2"
	jq -n --arg branch "$branch" --arg now "$now" '{meta:{branch:$branch,created_at:$now,updated_at:$now},notes:[]}'
}

cmd_path() {
	local branch=""
	while [ "$#" -gt 0 ]; do
		case "$1" in
		--branch)
			branch="${2:-}"
			shift 2
			;;
		--branch=*)
			branch="${1#--branch=}"
			shift
			;;
		-h | --help)
			usage
			exit 0
			;;
		*)
			printf 'Unknown option: %s\n' "$1" >&2
			exit 1
			;;
		esac
	done
	notes_file_for_branch "$(selected_branch "$branch")"
}

cmd_branches() {
	local json_output=0 root
	while [ "$#" -gt 0 ]; do
		case "$1" in
		--json)
			json_output=1
			shift
			;;
		-h | --help)
			usage
			exit 0
			;;
		*)
			printf 'Unknown option: %s\n' "$1" >&2
			exit 1
			;;
		esac
	done

	root="$(notes_root)"
	if [ ! -d "$root" ]; then
		[ "$json_output" -eq 1 ] && printf '[]\n'
		return 0
	fi

	if [ "$json_output" -eq 1 ]; then
		find "$root" -type f -name notes.json -print | sort | while IFS= read -r file; do
			local rel branch
			rel="${file#"$root"/}"
			branch="${rel%/notes.json}"
			jq -c --arg branch "$branch" --arg path "$file" '
				if type == "object" and ((.notes // []) | length) > 0 then
					{
						branch:(.meta.branch // $branch),
						notes_count:((.notes // []) | length),
						created_at:(.meta.created_at // ""),
						updated_at:(.meta.updated_at // ""),
						path:$path
					}
				else empty end
			' "$file"
		done | jq -s '.'
	else
		find "$root" -type f -name notes.json -print | sort | while IFS= read -r file; do
			local rel branch
			rel="${file#"$root"/}"
			branch="${rel%/notes.json}"
			jq -r --arg branch "$branch" --arg path "$file" '
				if type == "object" and ((.notes // []) | length) > 0 then
					[.meta.branch // $branch, ((.notes // []) | length), (.meta.updated_at // ""), $path] | @tsv
				else empty end
			' "$file"
		done
	fi
}

cmd_add() {
	local file="" line="" body="" title="" severity="" source="pi" branch="" base_ref="" provider="" pr_id=""

	while [ "$#" -gt 0 ]; do
		case "$1" in
		--file)
			file="${2:-}"
			shift 2
			;;
		--file=*)
			file="${1#--file=}"
			shift
			;;
		--line)
			line="${2:-}"
			shift 2
			;;
		--line=*)
			line="${1#--line=}"
			shift
			;;
		--body)
			body="${2:-}"
			shift 2
			;;
		--body=*)
			body="${1#--body=}"
			shift
			;;
		--title)
			title="${2:-}"
			shift 2
			;;
		--title=*)
			title="${1#--title=}"
			shift
			;;
		--severity)
			severity="${2:-}"
			shift 2
			;;
		--severity=*)
			severity="${1#--severity=}"
			shift
			;;
		--source)
			source="${2:-}"
			shift 2
			;;
		--source=*)
			source="${1#--source=}"
			shift
			;;
		--branch)
			branch="${2:-}"
			shift 2
			;;
		--branch=*)
			branch="${1#--branch=}"
			shift
			;;
		--base-ref)
			base_ref="${2:-}"
			shift 2
			;;
		--base-ref=*)
			base_ref="${1#--base-ref=}"
			shift
			;;
		--provider)
			provider="${2:-}"
			shift 2
			;;
		--provider=*)
			provider="${1#--provider=}"
			shift
			;;
		--pr-id)
			pr_id="${2:-}"
			shift 2
			;;
		--pr-id=*)
			pr_id="${1#--pr-id=}"
			shift
			;;
		-h | --help)
			usage
			exit 0
			;;
		*)
			printf 'Unknown option: %s\n' "$1" >&2
			usage
			exit 1
			;;
		esac
	done

	if [ -z "$file" ] || [ -z "$line" ] || [ -z "$body" ]; then
		printf 'add requires --file, --line, and --body.\n' >&2
		usage
		exit 1
	fi
	if ! [[ "$line" =~ ^[0-9]+$ ]] || [ "$line" -lt 1 ]; then
		printf 'Invalid --line: %s\n' "$line" >&2
		exit 1
	fi
	line="$((10#$line))"

	case "$severity" in
	"" | critical | important | minor) ;;
	*)
		printf 'Invalid --severity: %s\n' "$severity" >&2
		exit 1
		;;
	esac
	case "$source" in
	pi | manual) ;;
	*)
		printf 'Invalid --source: %s\n' "$source" >&2
		exit 1
		;;
	esac

	local wt rel id created selected note_file note_json
	wt="$(worktree_root)"
	selected="$(selected_branch "$branch")"
	rel="$(relative_path "$wt" "$file")"
	id="$(new_id)"
	created="$(now_utc)"
	note_file="$(notes_file_for_branch "$selected")"
	[ -n "$base_ref" ] || base_ref="$(default_base_ref)"

	note_json="$({
		jq -cn \
			--arg id "$id" \
			--arg source "$source" \
			--arg provider "$provider" \
			--arg pr_id "$pr_id" \
			--arg branch "$selected" \
			--arg head_sha "$(head_sha)" \
			--arg base_sha "$(base_sha_for "$base_ref")" \
			--arg base_ref "$base_ref" \
			--arg remote_url "$(remote_url)" \
			--arg file_path "$rel" \
			--argjson line "$line" \
			--arg severity "$severity" \
			--arg title "$title" \
			--arg body "$body" \
			--arg created_at "$created" \
			'{
				id:$id,
				source:$source,
				branch:$branch,
				file_path:$file_path,
				line:$line,
				body:$body,
				created_at:$created_at
			}
			+ (if $provider == "" then {} else {provider:$provider} end)
			+ (if $pr_id == "" then {} else {pr_id:$pr_id} end)
			+ (if $head_sha == "" then {} else {head_sha:$head_sha} end)
			+ (if $base_sha == "" then {} else {base_sha:$base_sha} end)
			+ (if $base_ref == "" then {} else {base_ref:$base_ref} end)
			+ (if $remote_url == "" then {} else {remote_url:$remote_url} end)
			+ (if $severity == "" then {} else {severity:$severity} end)
			+ (if $title == "" then {} else {title:$title} end)'
	})"

	if [ -s "$note_file" ]; then
		jq --argjson note "$note_json" --arg branch "$selected" --arg now "$created" '
			if type == "object" then . else {meta:{branch:$branch,created_at:$now},notes:[]} end
			| .meta.branch = (.meta.branch // $branch)
			| .meta.created_at = (.meta.created_at // $now)
			| .meta.updated_at = $now
			| .notes = ((.notes // []) + [$note])
		' "$note_file" | write_json "$note_file"
	else
		jq -n --argjson note "$note_json" --arg branch "$selected" --arg now "$created" '{meta:{branch:$branch,created_at:$now,updated_at:$now},notes:[$note]}' | write_json "$note_file"
	fi
	printf '%s\n' "$id"
}

cmd_update() {
	local id="" file="" line="" body="" title="" severity="" source="" branch="" base_ref="" provider="" pr_id=""
	local has_file=0 has_line=0 has_body=0 has_title=0 has_severity=0 has_source=0 has_base_ref=0 has_provider=0 has_pr_id=0

	while [ "$#" -gt 0 ]; do
		case "$1" in
		--file)
			file="${2:-}"
			has_file=1
			shift 2
			;;
		--file=*)
			file="${1#--file=}"
			has_file=1
			shift
			;;
		--line)
			line="${2:-}"
			has_line=1
			shift 2
			;;
		--line=*)
			line="${1#--line=}"
			has_line=1
			shift
			;;
		--body)
			body="${2:-}"
			has_body=1
			shift 2
			;;
		--body=*)
			body="${1#--body=}"
			has_body=1
			shift
			;;
		--title)
			title="${2:-}"
			has_title=1
			shift 2
			;;
		--title=*)
			title="${1#--title=}"
			has_title=1
			shift
			;;
		--severity)
			severity="${2:-}"
			has_severity=1
			shift 2
			;;
		--severity=*)
			severity="${1#--severity=}"
			has_severity=1
			shift
			;;
		--source)
			source="${2:-}"
			has_source=1
			shift 2
			;;
		--source=*)
			source="${1#--source=}"
			has_source=1
			shift
			;;
		--branch)
			branch="${2:-}"
			shift 2
			;;
		--branch=*)
			branch="${1#--branch=}"
			shift
			;;
		--base-ref)
			base_ref="${2:-}"
			has_base_ref=1
			shift 2
			;;
		--base-ref=*)
			base_ref="${1#--base-ref=}"
			has_base_ref=1
			shift
			;;
		--provider)
			provider="${2:-}"
			has_provider=1
			shift 2
			;;
		--provider=*)
			provider="${1#--provider=}"
			has_provider=1
			shift
			;;
		--pr-id)
			pr_id="${2:-}"
			has_pr_id=1
			shift 2
			;;
		--pr-id=*)
			pr_id="${1#--pr-id=}"
			has_pr_id=1
			shift
			;;
		-h | --help)
			usage
			exit 0
			;;
		*)
			if [ -z "$id" ]; then
				id="$1"
				shift
			else
				printf 'Unknown argument: %s\n' "$1" >&2
				exit 1
			fi
			;;
		esac
	done

	if [ -z "$id" ]; then
		printf 'update requires a note id.\n' >&2
		exit 1
	fi
	if [ "$has_file" -eq 1 ] && [ -z "$file" ]; then
		printf 'update --file cannot be empty.\n' >&2
		exit 1
	fi
	if [ "$has_line" -eq 1 ]; then
		if ! [[ "$line" =~ ^[0-9]+$ ]] || [ "$line" -lt 1 ]; then
			printf 'Invalid --line: %s\n' "$line" >&2
			exit 1
		fi
		line="$((10#$line))"
	fi
	if [ "$has_body" -eq 1 ] && [ -z "$body" ]; then
		printf 'update --body cannot be empty.\n' >&2
		exit 1
	fi
	if [ "$has_severity" -eq 1 ]; then
		case "$severity" in
		"" | critical | important | minor) ;;
		*)
			printf 'Invalid --severity: %s\n' "$severity" >&2
			exit 1
			;;
		esac
	fi
	if [ "$has_source" -eq 1 ]; then
		case "$source" in
		pi | manual) ;;
		*)
			printf 'Invalid --source: %s\n' "$source" >&2
			exit 1
			;;
		esac
	fi
	if [ "$has_file" -eq 0 ] && [ "$has_line" -eq 0 ] && [ "$has_body" -eq 0 ] && [ "$has_title" -eq 0 ] && [ "$has_severity" -eq 0 ] && [ "$has_source" -eq 0 ] && [ "$has_base_ref" -eq 0 ] && [ "$has_provider" -eq 0 ] && [ "$has_pr_id" -eq 0 ]; then
		printf 'update requires at least one field option.\n' >&2
		exit 1
	fi

	local wt rel selected note_file now base_sha current_head current_remote
	wt="$(worktree_root)"
	selected="$(selected_branch "$branch")"
	note_file="$(notes_file_for_branch "$selected")"
	[ -f "$note_file" ] || {
		printf 'Note not found: %s\n' "$id" >&2
		exit 1
	}
	jq -e --arg id "$id" 'if type == "object" then any((.notes // [])[]; .id == $id) else false end' "$note_file" >/dev/null || {
		printf 'Note not found: %s\n' "$id" >&2
		exit 1
	}

	now="$(now_utc)"
	current_head="$(head_sha)"
	current_remote="$(remote_url)"
	rel="$file"
	[ "$has_file" -eq 0 ] || rel="$(relative_path "$wt" "$file")"
	base_sha=""
	if [ "$has_base_ref" -eq 1 ] && [ -n "$base_ref" ]; then
		base_sha="$(base_sha_for "$base_ref")"
	fi

	jq \
		--arg id "$id" \
		--arg branch "$selected" \
		--arg now "$now" \
		--arg head_sha "$current_head" \
		--arg remote_url "$current_remote" \
		--arg has_file "$has_file" \
		--arg file_path "$rel" \
		--arg has_line "$has_line" \
		--argjson line "${line:-0}" \
		--arg has_body "$has_body" \
		--arg body "$body" \
		--arg has_title "$has_title" \
		--arg title "$title" \
		--arg has_severity "$has_severity" \
		--arg severity "$severity" \
		--arg has_source "$has_source" \
		--arg source "$source" \
		--arg has_base_ref "$has_base_ref" \
		--arg base_ref "$base_ref" \
		--arg base_sha "$base_sha" \
		--arg has_provider "$has_provider" \
		--arg provider "$provider" \
		--arg has_pr_id "$has_pr_id" \
		--arg pr_id "$pr_id" \
		'
			def set_string($key; $enabled; $value):
				if $enabled == "1" then
					if $value == "" then del(.[$key]) else .[$key] = $value end
				else . end;

			if type == "object" then . else {meta:{branch:$branch,created_at:$now},notes:[]} end
			| .meta.branch = (.meta.branch // $branch)
			| .meta.created_at = (.meta.created_at // $now)
			| .meta.updated_at = $now
			| .notes = ((.notes // []) | map(
				if .id == $id then
					.
					| .branch = $branch
					| .updated_at = $now
					| set_string("head_sha"; "1"; $head_sha)
					| set_string("remote_url"; "1"; $remote_url)
					| set_string("file_path"; $has_file; $file_path)
					| if $has_line == "1" then .line = $line else . end
					| if $has_body == "1" then .body = $body else . end
					| set_string("title"; $has_title; $title)
					| set_string("severity"; $has_severity; $severity)
					| if $has_source == "1" then .source = $source else . end
					| set_string("provider"; $has_provider; $provider)
					| set_string("pr_id"; $has_pr_id; $pr_id)
					| if $has_base_ref == "1" then
						if $base_ref == "" then
							del(.base_ref) | del(.base_sha)
						else
							.base_ref = $base_ref | set_string("base_sha"; "1"; $base_sha)
						end
					else . end
				else . end
			))
		' "$note_file" | write_json "$note_file"
	printf '%s\n' "$id"
}

cmd_list() {
	local json_output=0 branch="" selected note_file
	while [ "$#" -gt 0 ]; do
		case "$1" in
		--json)
			json_output=1
			shift
			;;
		--branch)
			branch="${2:-}"
			shift 2
			;;
		--branch=*)
			branch="${1#--branch=}"
			shift
			;;
		-h | --help)
			usage
			exit 0
			;;
		*)
			printf 'Unknown option: %s\n' "$1" >&2
			exit 1
			;;
		esac
	done

	selected="$(selected_branch "$branch")"
	note_file="$(notes_file_for_branch "$selected")"
	if [ ! -s "$note_file" ]; then
		[ "$json_output" -eq 1 ] && printf '[]\n'
		return 0
	fi

	if [ "$json_output" -eq 1 ]; then
		jq 'if type == "object" then (.notes // []) else [] end' "$note_file"
	else
		jq -r 'if type == "object" then ((.notes // [])[] | [.id, (.severity // "note"), ((.file_path // "") + ":" + ((.line // 0) | tostring)), (.title // ((.body // "") | split("\n")[0][0:80]))] | @tsv) else empty end' "$note_file"
	fi
}

cmd_delete() {
	local id="" branch="" selected note_file now
	while [ "$#" -gt 0 ]; do
		case "$1" in
		--branch)
			branch="${2:-}"
			shift 2
			;;
		--branch=*)
			branch="${1#--branch=}"
			shift
			;;
		*)
			if [ -z "$id" ]; then
				id="$1"
				shift
			else
				printf 'Unknown argument: %s\n' "$1" >&2
				exit 1
			fi
			;;
		esac
	done
	if [ -z "$id" ]; then
		printf 'delete requires a note id.\n' >&2
		exit 1
	fi

	selected="$(selected_branch "$branch")"
	note_file="$(notes_file_for_branch "$selected")"
	[ -f "$note_file" ] || return 0
	now="$(now_utc)"

	jq --arg branch "$selected" --arg id "$id" --arg now "$now" '
		if type == "object" then . else {meta:{branch:$branch,created_at:$now},notes:[]} end
		| .notes = ((.notes // []) | map(select(.id != $id)))
		| .meta.updated_at = $now
	' "$note_file" | write_json "$note_file"
	printf '%s\n' "$id"
}

cmd_clear() {
	local branch="" yes=0 selected note_file now
	while [ "$#" -gt 0 ]; do
		case "$1" in
		--yes)
			yes=1
			shift
			;;
		--branch)
			branch="${2:-}"
			shift 2
			;;
		--branch=*)
			branch="${1#--branch=}"
			shift
			;;
		*)
			printf 'Unknown option: %s\n' "$1" >&2
			exit 1
			;;
		esac
	done
	if [ "$yes" -ne 1 ]; then
		printf 'clear removes all notes for this branch. Re-run with --yes.\n' >&2
		exit 1
	fi

	selected="$(selected_branch "$branch")"
	note_file="$(notes_file_for_branch "$selected")"
	now="$(now_utc)"
	if [ -s "$note_file" ]; then
		jq --arg branch "$selected" --arg now "$now" '
			if type == "object" then . else {meta:{branch:$branch,created_at:$now},notes:[]} end
			| .meta.updated_at = $now
			| .notes = []
		' "$note_file" | write_json "$note_file"
	else
		empty_document "$selected" "$now" | write_json "$note_file"
	fi
	printf '%s\n' "$note_file"
}

cmd_delete_branch() {
	local branch="" yes=0 dir file
	while [ "$#" -gt 0 ]; do
		case "$1" in
		--yes)
			yes=1
			shift
			;;
		--branch)
			branch="${2:-}"
			shift 2
			;;
		--branch=*)
			branch="${1#--branch=}"
			shift
			;;
		*)
			if [ -z "$branch" ]; then
				branch="$1"
				shift
			else
				printf 'Unknown argument: %s\n' "$1" >&2
				exit 1
			fi
			;;
		esac
	done
	if [ -z "$branch" ]; then
		printf 'delete-branch requires --branch <branch>.\n' >&2
		exit 1
	fi
	if [ "$yes" -ne 1 ]; then
		printf 'delete-branch removes the branch notes file. Re-run with --yes.\n' >&2
		exit 1
	fi

	dir="$(notes_dir_for_branch "$branch")"
	file="$dir/notes.json"
	rm -f "$file"
	while [ "$dir" != "$(notes_root)" ] && [ "$dir" != "/" ]; do
		rmdir "$dir" 2>/dev/null || break
		dir="$(dirname "$dir")"
	done
	printf '%s\n' "$file"
}

case "${1:-}" in
path)
	shift
	cmd_path "$@"
	;;
branches)
	shift
	cmd_branches "$@"
	;;
add)
	shift
	cmd_add "$@"
	;;
update)
	shift
	cmd_update "$@"
	;;
list)
	shift
	cmd_list "$@"
	;;
delete)
	shift
	cmd_delete "$@"
	;;
clear)
	shift
	cmd_clear "$@"
	;;
delete-branch)
	shift
	cmd_delete_branch "$@"
	;;
-h | --help | "")
	usage
	;;
*)
	printf 'Unknown command: %s\n' "$1" >&2
	usage
	exit 1
	;;
esac
